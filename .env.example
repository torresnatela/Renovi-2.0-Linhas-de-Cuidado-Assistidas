# Copie para `.env` e ajuste. NUNCA commite o .env real.
# Estes valores batem com o docker-compose local (deploy/docker-compose.yml).

# --- Servidor ---
RENOVI_ENV=local
RENOVI_HTTP_ADDR=:8090
RENOVI_LOG_LEVEL=info

# --- Banco próprio (Postgres renovi_care) ---
# Papel duplo, um par de credenciais para cada:
#   - A APLICAÇÃO conecta como renovi_app (role restrito criado pela migration
#     0008): sem UPDATE/DELETE em journey_event, que é append-only no BANCO.
#   - As MIGRATIONS rodam como owner (renovi), pois criam tabelas e o próprio
#     role renovi_app. Descomente a linha MIGRATE para separar os dois; se ela
#     ficar vazia, o `migrate` cai na URL da aplicação (que não tem privilégio de
#     DDL — então em setup com split é preciso defini-la).
RENOVI_CARE_DATABASE_URL=postgres://renovi_app:renovi_app@localhost:5432/renovi_care?sslmode=disable
# RENOVI_CARE_MIGRATE_DATABASE_URL=postgres://renovi:renovi@localhost:5432/renovi_care?sslmode=disable

# --- Banco legado (MySQL) — leitura de slots + escrita restrita à agenda.
#     Opcional no MVP inicial; o mock do compose sobe em localhost:3306. ---
# NÃO acrescente parseTime/loc aqui: o adapter FORÇA os dois
# (parseTime=true, loc=America/Sao_Paulo) e recusa subir se o DSN pedir outro
# fuso. As colunas datetime do legado são ingênuas e significam hora de São
# Paulo — isso é propriedade do dado, não configuração de ambiente. Com o
# default (UTC), 09:00 lá viraria 06:00 aqui, em silêncio.
RENOVI_LEGACY_DATABASE_URL=renovi:renovi@tcp(localhost:3306)/renovi_legacy

# --- Banco Gestão 2.0 (Postgres, SOMENTE LEITURA).
#     Opcional no MVP inicial; o mock do compose sobe em localhost:5433. ---
RENOVI_GESTAO_DATABASE_URL=postgres://renovi:renovi@localhost:5433/gestao?sslmode=disable

# --- Doutor ao Vivo (teleconsulta) — obrigatório fora de `local`.
#     A chave vai no header x-api-key. NUNCA commite a real: este arquivo é o exemplo.
#     Homologação: https://api.v2.hom.doutoraovivo.com.br
#     Produção:    https://api.v2.doutoraovivo.com.br  (NUNCA rode `make dav-probe` contra ela) ---
RENOVI_DAV_BASE_URL=https://api.v2.hom.doutoraovivo.com.br
RENOVI_DAV_API_KEY=

# --- Sessão (ADR-010). O default de SECURE é true; false só em dev sem TLS. ---
# RENOVI_SESSION_TTL=12h
# RENOVI_SESSION_COOKIE_SECURE=false

# --- Ajuste fino da DAV. O default de 30s é PROPOSITALMENTE acima do teto de 29s
#     do AWS API Gateway dela — ver docs/DAV-API-NOTAS.md. ---
# RENOVI_DAV_TIMEOUT=30s
# RENOVI_DAV_MAX_ATTEMPTS=2

# --- Admin / linhas de cuidado (Slice 1) ---
# RENOVI_ADMIN_TOKEN: token estático das rotas /admin (header X-Admin-Token).
# Vazio (o default) DESLIGA as rotas admin por completo — não há tela de admin
# no Slice 1, então ficar sem definir é seguro. Só defina para rodar o roteiro
# manual de docs/slice1.http (ex.: RENOVI_ADMIN_TOKEN=dev-admin-token).
RENOVI_ADMIN_TOKEN=

# RENOVI_TEST_ENDPOINTS: liga as rotas internas de teste (ex.: forçar status de
# consulta). SEMPRE false aqui — true só em dev, na mão, quando for rodar o
# roteiro manual. A API RECUSA subir com true em RENOVI_ENV=production.
RENOVI_TEST_ENDPOINTS=false

# --- Ingestão da Gestão (push, ADR-043) ---
# As três variáveis abaixo, juntas, LIGAM as rotas /integration/gestao. Vazias (o
# default) as DESLIGAM — seguro no dia a dia. Só defina para rodar docs/ingestion.http.
#
# RENOVI_GESTAO_INTEGRATION_TOKEN: token estático que a Gestão manda em
# X-Integration-Token. Segredo; NUNCA logado. Vazio desliga as rotas.
RENOVI_GESTAO_INTEGRATION_TOKEN=
# RENOVI_CPF_PEPPER: chave do HMAC-SHA256 do CPF (cpf_hmac). COMPARTILHADA com a
# Gestão — os dois lados precisam do MESMO valor para casar a pessoa. Segredo;
# obrigatório em staging/produção. O cadastro passa a gravar cpf_hmac quando setado.
RENOVI_CPF_PEPPER=
# RENOVI_WEB_BASE_URL: base pública do front, usada para montar o invite_url do
# convite. Em local cai no dev server do Vite; com o token de integração setado,
# é obrigatória (senão o convite apontaria para lugar nenhum).
# RENOVI_WEB_BASE_URL=http://localhost:5173
# RENOVI_INVITE_TTL: validade do token de onboarding (default 7 dias / 168h).
# RENOVI_INVITE_TTL=168h
