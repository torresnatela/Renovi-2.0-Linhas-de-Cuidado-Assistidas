# Caddy INTERNO do container web (imagem renovi-care-web): serve só a SPA.
#
# O TLS, o domínio (app.renovisaude.com.br) e o roteamento /api -> care-api:8090
# ficam no Caddy de BORDA da VPS (/opt/renovi/Caddyfile, projeto compose
# preexistente "renovi") — ver deploy/edge-snippet.Caddyfile e docs/DEPLOY.md.
{
	# Sem admin API: container imutável, config nunca muda em runtime.
	admin off
	auto_https off
}

:80 {
	root * /srv/web
	encode gzip

	# SPA fallback: rotas do React caem no index.html.
	try_files {path} /index.html
	file_server

	# Assets do Vite têm hash no nome -> cache imutável.
	header /assets/* Cache-Control "public, max-age=31536000, immutable"
	# index.html nunca deve ser cacheado (aponta para os assets novos).
	header / Cache-Control "no-cache"
}
